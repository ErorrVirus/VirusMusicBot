# Discord Bot Token
DISCORD_TOKEN=your_discord_bot_token_here

# Spotify Metadata API (Required for Spotify links)
# Go to https://developer.spotify.com/dashboard to get these
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Lavalink Node configuration (Local node runs automatically in Docker)
LAVALINK_HOST=127.0.0.1
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass

# Render Web Service Port (Express dummy server keeps Render happy)
PORT=10000
