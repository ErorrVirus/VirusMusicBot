# ============================================================
#  VirusMusicPro — Environment Configuration
#  Copy this file to .env and fill in your credentials.
#  NEVER commit .env to version control.
# ============================================================

# ── Discord ──────────────────────────────────────────────────
# Create a bot at https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# ── Spotify ──────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# ── Spotify OAuth (REQUIRED for playlist & album support) ────
# Since late 2024, Spotify requires real user authentication for
# playlist and album endpoints (even public ones).
#
# Step 1: In the Spotify Dashboard, add this exact URI to
#         "Redirect URIs" for your app:
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback
#
# Step 2: Run the helper script once:
#             python spotify_auth.py
#         It will open your browser, you log in, and it prints
#         your refresh token.  Paste it below.
SPOTIFY_REFRESH_TOKEN=your_refresh_token_here

# ── Optional Tuning ──────────────────────────────────────────
# Maximum tracks that can be queued per guild (default: 200)
MAX_QUEUE_SIZE=200

# Inactivity timeout in seconds before the bot auto-disconnects (default: 300)
INACTIVITY_TIMEOUT=300
